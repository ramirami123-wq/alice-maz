      "settings": {
        "custom_liquid": "<style>\n.smartsouq-compare {\n  max-width: 900px;\n  margin: 40px auto;\n  overflow-x: auto;\n}\n\n.smartsouq-compare h2 {\n  text-align: center;\n  font-size: 32px;\n  margin-bottom: 25px;\n  color: #222;\n}\n\n.smartsouq-compare table {\n  width: 100%;\n  border-collapse: collapse;\n  border-radius: 15px;\n  overflow: hidden;\n  box-shadow: 0 5px 20px rgba(0,0,0,0.08);\n}\n\n.smartsouq-compare th {\n  background: #000;\n  color: #fff;\n  padding: 18px;\n  font-size: 18px;\n}\n\n.smartsouq-compare td {\n  padding: 16px;\n  text-align: center;\n  border-bottom: 1px solid #eee;\n  font-size: 16px;\n}\n\n.smartsouq-compare tr:nth-child(even) {\n  background: #fafafa;\n}\n\n.smartsouq-compare .yes {\n  color: #1ba94c;\n  font-weight: bold;\n  font-size: 18px;\n}\n\n.smartsouq-compare .no {\n  color: #e63946;\n  font-weight: bold;\n  font-size: 18px;\n}\n\n.smartsouq-compare .brand {\n  font-weight: bold;\n  color: #000;\n}\n</style>\n\n<div class=\"smartsouq-compare\">\n  <h2>Why Choose Our Brush Cleaner?</h2>\n\n  <table>\n    <thead>\n      <tr>\n        <th>Features</th>\n        <th>Our Brush Cleaner</th>\n        <th>Others</th>\n      </tr>\n    </thead>\n\n    <tbody>\n      <tr>\n        <td>Deep Cleans Brushes</td>\n        <td class=\"yes\">✔ Yes</td>\n        <td class=\"no\">✘ No</td>\n      </tr>\n\n      <tr>\n        <td>Fast Drying Function</td>\n        <td class=\"yes\">✔ Yes</td>\n        <td class=\"no\">✘ No</td>\n      </tr>\n\n      <tr>\n        <td>Fits Multiple Brush Sizes</td>\n        <td class=\"yes\">✔ Yes</td>\n        <td class=\"no\">✘ No</td>\n      </tr>\n\n      <tr>\n        <td>Touch-Screen Controls</td>\n        <td class=\"yes\">✔ Yes</td>\n        <td class=\"no\">✘ No</td>\n      </tr>\n\n      <tr>\n        <td>Compact & Stylish Design</td>\n        <td class=\"yes\">✔ Yes</td>\n        <td class=\"no\">✘ No</td>\n      </tr>\n\n      <tr>\n        <td>Saves Time</td>\n        <td class=\"yes\">✔ Yes</td>\n        <td class=\"no\">✘ No</td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
